# Copy this file to .env and fill in your credentials.
# .env is gitignored and never committed.

# EPO Open Patent Services API (free at https://developers.epo.org)
EPO_KEY=your_consumer_key_here
EPO_SECRET=your_consumer_secret_here

# Anthropic API (for NLP invention summaries — optional)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here
